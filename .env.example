# Database
DATABASE_URL=postgresql+asyncpg://postermind:postermind@postgres:5432/postermind
DATABASE_URL_SYNC=postgresql://postermind:postermind@postgres:5432/postermind

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# OpenAI (GPT-4o for prompt generation)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Stable Diffusion / Flux Kontext
STABLE_DIFFUSION_API_URL=https://api.stability.ai/v1/generation/stable-diffusion-xl-1024-v1-0/text-to-image
STABLE_DIFFUSION_API_KEY=your-key-here
IMAGE_GEN_BACKEND=stability  # options: stability, flux, openai

# Cloudflare R2 (or AWS S3)
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET=postermind
R2_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://your-bucket.r2.cloudflarestorage.com
STORAGE_BACKEND=r2  # options: r2, s3, local
